  "faq_section": {
    "eyebrow": "Common Questions",
    "heading": "What Trade Business Owners Ask Us First",
    "sub": "Straight answers to the questions we hear most often.",
    "faqs": [
      {
        "question": "How much does a trade website cost?",
        "answer": "Pricing depends on what you need — a standard trade website typically starts from around $2,500. Websites with lead systems, booking tools, or quote calculators are priced based on scope. We provide clear, itemised pricing before anything starts. Book a free call and we'll give you an honest figure within 24 hours."
      },
      {
        "question": "How long does it take to build a trade website?",
        "answer": "Most trade websites are designed, built, and launched within 3 to 5 weeks of kick-off. More complex builds with multiple systems can take 6 to 8 weeks. We'll give you a realistic timeline in your proposal — and we stick to it."
      },
      {
        "question": "Do I need to provide content and photos?",
        "answer": "We write all the copy for your site as part of the project — you don't need to provide anything except some basic information about your business. If you have photos of your work, great — we'll use them. If not, we have access to high-quality stock photography that works for most trades."
      },
      {
        "question": "Will my website show up on Google?",
        "answer": "Every website we build includes on-page SEO foundations — keyword research, proper page structure, fast load speeds, and Google Business Profile setup. This gives you the best possible start. For more aggressive local SEO growth, we also offer an ongoing Local SEO Foundations service."
      },
      {
        "question": "What happens after my website launches?",
        "answer": "We offer ongoing Website Management plans that keep your site updated, secure, and improving month to month. Alternatively, we hand over full ownership and you manage it yourself — no lock-in contracts. Either way, we're available for support."
      }
    ]
